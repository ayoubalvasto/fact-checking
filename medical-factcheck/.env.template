# Medical Fact-Check System - Environment Configuration Template
# Copy to .env.production and fill in secure values

# ============ DATABASE CONFIGURATION ============
# REQUIRED: PostgreSQL connection string with secure credentials
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://medical_user:YOUR_SECURE_PASSWORD@db.example.com:5432/medical_factcheck
SQLALCHEMY_DATABASE_URL=${DATABASE_URL}

# ============ REDIS CONFIGURATION ============
# Redis connection for caching
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ API CONFIGURATION ============
# Backend API settings
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO
API_TITLE=Medical Fact-Check API
API_VERSION=1.0.0

# ============ FRONTEND CONFIGURATION ============
# Next.js Frontend URLs and timeouts
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_FEATURE_VIDEO_UPLOAD=true
NEXT_PUBLIC_FEATURE_BATCH_VERIFICATION=true

# ============ ML/NLP CONFIGURATION ============
# Model paths and settings
MODEL_PATH=/models
NER_MODEL_NAME=bert-base-multilingual-cased
CLASSIFICATION_MODEL=facebook/bart-large-mnli
TF_ENABLE_ONEDNN_OPTS=0

# ============ SECURITY & AUTHENTICATION ============
# JWT secret for API token generation
JWT_SECRET=your-secret-here-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS settings
CORS_ORIGINS=["https://example.com", "https://www.example.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "OPTIONS"]
CORS_ALLOW_HEADERS=["Content-Type", "X-Request-ID"]

# ============ MONITORING & LOGGING ============
# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging configuration
LOG_FORMAT=json
LOG_OUTPUT_PATH=/var/log/medical-factcheck

# ============ PERFORMANCE TUNING ============
# Connection pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Caching TTLs (in seconds)
CACHE_TTL_VERIFICATION=604800  # 7 days
CACHE_TTL_DATASET=86400       # 1 day
CACHE_TTL_STATS=3600          # 1 hour

# Batch processing
MAX_BATCH_SIZE=10
MAX_CONCURRENT_TASKS=5

# ============ STORAGE CONFIGURATION ============
# Where to save generated datasets
DATASET_OUTPUT_PATH=/data/datasets
UPLOAD_PATH=/data/uploads
MAX_UPLOAD_SIZE_MB=100

# ============ EMAIL NOTIFICATIONS (Optional) ============
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=admin@example.com

# ============ EXTERNAL SERVICES ============
# Third-party API integrations
OPENAI_API_KEY=  # If using OpenAI for LLM verification
HUGGINGFACE_API_KEY=  # For HuggingFace model access

# ============ DATA BACKUP ============
# Backup configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups
