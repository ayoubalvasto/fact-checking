# Frontend Environment Variables - Example/Template
# Copy this file to .env.local and update values for your environment

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_BATCH_VERIFICATION=true
NEXT_PUBLIC_ENABLE_VIDEO_UPLOAD=false

# Analytics & Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_TRACKING_ID=

# App Metadata
NEXT_PUBLIC_APP_NAME=Medical Fact-Check
NEXT_PUBLIC_APP_VERSION=1.0.0
